{
  "name": "@paperclipai/plugin-company",
  "version": "0.6.0",
  "license": "MIT",
  "homepage": "https://github.com/nex8s/company-dev",
  "bugs": {
    "url": "https://github.com/nex8s/company-dev/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nex8s/company-dev",
    "directory": "packages/plugin-company"
  },
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./*": {
        "types": "./dist/*.d.ts",
        "import": "./dist/*.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@paperclipai/db": "workspace:*",
    "@paperclipai/shared": "workspace:*",
    "drizzle-orm": "^0.38.4",
    "express": "^5.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.6.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
